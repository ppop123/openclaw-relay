{
  "name": "@openclaw/relay",
  "version": "0.3.0",
  "description": "OpenClaw Relay gateway plugin",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "openclaw.plugin.json"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "smoke": "bash ../scripts/smoke-openclaw-plugin.sh"
  },
  "peerDependencies": {
    "openclaw": ">=0.0.0"
  },
  "devDependencies": {
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=22"
  },
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ],
    "channel": {
      "id": "relay",
      "label": "Relay",
      "selectionLabel": "Relay",
      "docsPath": "/channels/relay",
      "docsLabel": "relay",
      "blurb": "Remote encrypted access to your OpenClaw gateway through a relay.",
      "order": 999
    },
    "install": {
      "localPath": "plugin"
    }
  }
}
