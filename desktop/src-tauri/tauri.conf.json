{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "OpenClaw Relay",
  "version": "0.5.0",
  "identifier": "cc.wanghui.openclawrelay",
  "build": {
    "frontendDist": "../../client"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "OpenClaw Relay",
        "width": 480,
        "height": 720,
        "minWidth": 380,
        "minHeight": 500,
        "resizable": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' wss://*; img-src 'self' data: blob:; style-src 'self' 'unsafe-inline'; script-src 'self'; font-src 'self' data:;"
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "dmg",
      "nsis"
    ],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper"
      }
    }
  }
}
